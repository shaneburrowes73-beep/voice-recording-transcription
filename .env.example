# Supabase Configuration (Public — next.config.js exposes NEXT_PUBLIC_* vars)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Configuration (Private — server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gmail SMTP Configuration (for transactional submission emails)
GMAIL_SMTP_USER=alerts@aisolutionsnet.net
GMAIL_SMTP_APP_PASSWORD=your-gmail-app-password

# Email Notification
SUBMISSION_NOTIFY_EMAIL=aisolutions@aisolutionsnet.net
