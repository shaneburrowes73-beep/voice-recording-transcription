# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Flask Configuration
FLASK_ENV=development
FLASK_PORT=5000

# Model Configuration
MODEL_PATH=./data/models/accent_classifier_best.pt
DEVICE=cuda  # or 'cpu' if no GPU available

# Feature Extraction
SAMPLE_RATE=16000
N_MFCC=13
N_FEATURES=50

# Confidence Thresholds (loaded from config, override here if needed)
CONFIDENCE_THRESHOLD_BARBADIAN=0.68
CONFIDENCE_THRESHOLD_STANDARD=0.80
